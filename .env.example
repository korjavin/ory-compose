# =============================================================================
# Ory Kratos + Hydra + Login UI — Portainer stack envs
#
# All values below should be set in the Portainer stack's environment-variables
# panel — do NOT commit a real .env file. The compose stack reads env names,
# never a literal .env file on the server.
#
# Generate secrets with:  openssl rand -hex 32
# =============================================================================

# --- Docker images (pinned to vendored GHCR by default) ---
KRATOS_IMAGE=ghcr.io/korjavin/kratos-vendor:latest
HYDRA_IMAGE=ghcr.io/korjavin/hydra-vendor:latest
LOGIN_UI_IMAGE=ghcr.io/korjavin/kratos-selfservice-ui-node-vendor:latest
ENVSUBST_IMAGE=alpine:3.20

# --- Container names (optional overrides) ---
KRATOS_CONFIG_CONTAINER_NAME=ory-kratos-config
KRATOS_MIGRATE_CONTAINER_NAME=ory-kratos-migrate
KRATOS_CONTAINER_NAME=ory-kratos
HYDRA_MIGRATE_CONTAINER_NAME=ory-hydra-migrate
HYDRA_CONTAINER_NAME=ory-hydra
LOGIN_UI_CONTAINER_NAME=ory-login-ui

# --- Network / volume names ---
INTERNAL_NETWORK_NAME=ory_internal
TRAEFIK_NETWORK_NAME=traefik_default
KRATOS_VOLUME_NAME=ory_kratos-data
KRATOS_RENDERED_VOLUME_NAME=ory_kratos-rendered
HYDRA_VOLUME_NAME=ory_hydra-data

# --- Public hostnames (Traefik routes) ---
# These three MUST be DNS-resolvable to your host and have TLS via Traefik.
KRATOS_PUBLIC_HOST=kratos.example.com
HYDRA_PUBLIC_HOST=hydra.example.com
LOGIN_UI_HOST=auth.example.com

# Cookie domain shared between Kratos and the Login UI. Use a parent domain
# (e.g. ".example.com") if you want SSO cookies across multiple subdomains.
COOKIE_DOMAIN=.example.com

# --- Traefik integration ---
TRAEFIK_CERTRESOLVER=myresolver

# --- Kratos data store ---
# SQLite by default. Switch to postgres://... if you ever need to scale out.
KRATOS_DSN=sqlite:///var/lib/kratos/db.sqlite?_fk=true&mode=rwc

# --- Kratos secrets (REQUIRED — generate with `openssl rand -hex 32`) ---
KRATOS_COOKIE_SECRET=change-me-32-bytes-hex
KRATOS_CIPHER_SECRET=change-me-exactly-32-bytes-hex-required

# --- Kratos behavior ---
KRATOS_LOG_LEVEL=info
KRATOS_TOTP_ISSUER=Ory Kratos

# --- Kratos email (for verification + recovery) ---
# Format: smtps://user:pass@host:port/?skip_ssl_verify=true
# Leave the default if you don't want to wire SMTP yet — recovery/verification
# emails will silently fail until this is configured.
KRATOS_SMTP_CONNECTION_URI=smtps://user:pass@smtp.example.com:465/
KRATOS_SMTP_FROM_ADDRESS=no-reply@example.com
KRATOS_SMTP_FROM_NAME=Ory

# --- Google OIDC provider ---
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI:
#   https://${KRATOS_PUBLIC_HOST}/self-service/methods/oidc/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Pocket-ID OIDC provider ---
# In Pocket-ID, create an OIDC client. Redirect URI:
#   https://${KRATOS_PUBLIC_HOST}/self-service/methods/oidc/callback/pocket-id
# ISSUER_URL is your Pocket-ID base URL (must serve /.well-known/openid-configuration).
POCKET_ID_ISSUER_URL=https://pocket-id.example.com/
POCKET_ID_CLIENT_ID=
POCKET_ID_CLIENT_SECRET=

# --- Hydra data store ---
HYDRA_DSN=sqlite:///var/lib/hydra/db.sqlite?_fk=true&mode=rwc

# --- Hydra secrets (REQUIRED — generate with `openssl rand -hex 32`) ---
# SECRETS_SYSTEM rotates the symmetric encryption key. First entry is active;
# add older keys (comma-separated) only when rotating.
HYDRA_SECRETS_SYSTEM=change-me-32-bytes-hex
HYDRA_SECRETS_COOKIE=change-me-32-bytes-hex
HYDRA_PAIRWISE_SALT=change-me-32-bytes-hex

# --- Hydra behavior ---
HYDRA_ACCESS_TOKEN_STRATEGY=jwt
HYDRA_TTL_ACCESS_TOKEN=1h
HYDRA_TTL_REFRESH_TOKEN=720h
HYDRA_TTL_ID_TOKEN=1h
HYDRA_TTL_AUTH_CODE=10m
HYDRA_LOG_LEVEL=info
HYDRA_LOG_LEAK_SENSITIVE_VALUES=false
HYDRA_EXPOSE_INTERNAL_ERRORS=false
# Set to "true" only on first boot if you need to bypass the HTTPS check while
# debugging behind a non-TLS proxy. Leave "false" in production.
HYDRA_DEV_MODE=false

# --- Login UI secrets ---
LOGIN_UI_COOKIE_SECRET=change-me-32-bytes-hex
LOGIN_UI_CSRF_COOKIE_SECRET=change-me-32-bytes-hex
LOGIN_UI_CSRF_COOKIE_NAME=__Host-ory-ui-csrf
# Keep "false" in production. Only set true if you serve Login UI over plain HTTP.
LOGIN_UI_DISABLE_SECURE_CSRF=false
