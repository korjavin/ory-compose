# =============================================================================
# Ory Kratos + Hydra + Login UI — Portainer stack envs
#
# All values below should be set in the Portainer stack's environment-variables
# panel — do NOT commit a real .env file. The compose stack reads env names,
# never a literal .env file on the server.
#
# Generate secrets with:  openssl rand -hex 32
# =============================================================================

# --- Docker images ---
# Leave these UNSET in Portainer. The `deploy` branch's docker-compose.yml
# has each image already pinned to a concrete tag (managed by GitHub Actions
# — see image-tags.env in the deploy branch). Setting an env var here would
# override that pin and break the auto-update flow.
#
# Only set one if you intentionally want to pin a different version:
# KRATOS_IMAGE=ghcr.io/korjavin/kratos-vendor:d-abc123def456
# HYDRA_IMAGE=ghcr.io/korjavin/hydra-vendor:d-abc123def456
# LOGIN_UI_IMAGE=ghcr.io/korjavin/kratos-selfservice-ui-node-vendor:d-abc...
# CONSENT_IMAGE=ghcr.io/korjavin/ory-consent:<git-sha>
# KRATOS_CONFIG_IMAGE=ghcr.io/korjavin/ory-kratos-config:<git-sha>

# --- Container names (optional overrides) ---
KRATOS_CONFIG_CONTAINER_NAME=ory-kratos-config
KRATOS_MIGRATE_CONTAINER_NAME=ory-kratos-migrate
KRATOS_CONTAINER_NAME=ory-kratos
HYDRA_MIGRATE_CONTAINER_NAME=ory-hydra-migrate
HYDRA_CONTAINER_NAME=ory-hydra
LOGIN_UI_CONTAINER_NAME=ory-login-ui
CONSENT_CONTAINER_NAME=ory-consent

# --- Network / volume names ---
INTERNAL_NETWORK_NAME=ory_internal
TRAEFIK_NETWORK_NAME=traefik_default
KRATOS_VOLUME_NAME=ory_kratos-data
KRATOS_RENDERED_VOLUME_NAME=ory_kratos-rendered
HYDRA_VOLUME_NAME=ory_hydra-data

# --- Public hostnames (Traefik routes) ---
# Two hostnames, both DNS-resolvable to your host with TLS via Traefik:
#   LOGIN_UI_HOST  — the user-facing auth surface. Hosts the Login UI catch-all
#                    AND Kratos public API (path-routed: /self-service/*,
#                    /.well-known/*, /sessions/*, /schemas/*, /health/*) AND
#                    the consent service (/consent). Same origin → cookies and
#                    CSRF just work.
#   HYDRA_PUBLIC_HOST — Hydra's OAuth2/OIDC public API. Apps configure
#                    OIDC discovery at https://<HYDRA_PUBLIC_HOST>/.well-known/
#                    openid-configuration.
HYDRA_PUBLIC_HOST=hydra.example.com
LOGIN_UI_HOST=auth.example.com

# Cookie domain shared between Kratos and the Login UI. Use a parent domain
# (e.g. ".example.com") if you want SSO cookies across multiple subdomains.
COOKIE_DOMAIN=.example.com

# --- Traefik integration ---
TRAEFIK_CERTRESOLVER=myresolver

# --- Kratos data store ---
# SQLite by default. Switch to postgres://... if you ever need to scale out.
KRATOS_DSN=sqlite:///var/lib/kratos/db.sqlite?_fk=true&mode=rwc

# --- Kratos secrets (REQUIRED) ---
# COOKIE_SECRET: any 32+ char random string — `openssl rand -hex 32` works.
KRATOS_COOKIE_SECRET=change-me-32-bytes-hex
# CIPHER_SECRET: must be EXACTLY 32 chars (xchacha20-poly1305 key). Generate
# with `openssl rand -hex 16` (16 bytes → 32 hex chars). Using `-hex 32`
# produces 64 chars and Kratos will reject it.
KRATOS_CIPHER_SECRET=change-me-exactly-32-chars-aaaaaa

# --- Kratos behavior ---
KRATOS_LOG_LEVEL=info
KRATOS_TOTP_ISSUER=Ory Kratos
# Sign-in surface. Defaults lock everything except OIDC + passkeys.
# Flip to `true` only if you intentionally want a fallback method.
KRATOS_PASSWORD_ENABLED=false
KRATOS_CODE_LOGIN_ENABLED=false
# Onboarding is invite-only by default. Setting this to true re-opens the
# public registration flow (anyone with a Google/GitHub/etc. account can
# create a Kratos identity without a prior invitation).
KRATOS_REGISTRATION_ENABLED=false
# How long an invitation (recovery) link is valid. Also bounds the code TTL.
KRATOS_RECOVERY_LIFESPAN=1h

# --- WebAuthn / Passkeys ---
# RP_ID is the relying party identifier. It MUST be a registrable suffix of
# every origin where WebAuthn is used. Set to your cookie domain without the
# leading dot (e.g. "example.com" if COOKIE_DOMAIN=.example.com).
WEBAUTHN_RP_DISPLAY_NAME=Ory
WEBAUTHN_RP_ID=example.com

# --- Kratos email (for verification + recovery) ---
# Format: smtps://user:pass@host:port/?skip_ssl_verify=true
# Leave the default if you don't want to wire SMTP yet — recovery/verification
# emails will silently fail until this is configured.
KRATOS_SMTP_CONNECTION_URI=smtps://user:pass@smtp.example.com:465/
KRATOS_SMTP_FROM_ADDRESS=no-reply@example.com
KRATOS_SMTP_FROM_NAME=Ory

# --- Google OIDC provider ---
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI:
#   https://${LOGIN_UI_HOST}/self-service/methods/oidc/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Pocket-ID OIDC provider ---
# In Pocket-ID, create an OIDC client. Redirect URI:
#   https://${LOGIN_UI_HOST}/self-service/methods/oidc/callback/pocket-id
# ISSUER_URL is your Pocket-ID base URL (must serve /.well-known/openid-configuration).
# NOTE: NO trailing slash. Pocket-ID's .well-known/openid-configuration
# returns `issuer` without a slash; Kratos rejects with "issuer did not
# match" if they differ.
POCKET_ID_ISSUER_URL=https://pocket-id.example.com
POCKET_ID_CLIENT_ID=
POCKET_ID_CLIENT_SECRET=

# --- GitHub OIDC provider ---
# Create at https://github.com/settings/developers (OAuth App).
# Authorization callback URL:
#   https://${LOGIN_UI_HOST}/self-service/methods/oidc/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- GitLab OIDC provider ---
# Create at https://gitlab.com/-/profile/applications (or your self-hosted GitLab).
# Redirect URI:
#   https://${LOGIN_UI_HOST}/self-service/methods/oidc/callback/gitlab
# Set GITLAB_ISSUER_URL to your GitLab base URL (no trailing slash). For
# gitlab.com use https://gitlab.com.
GITLAB_ISSUER_URL=https://gitlab.com
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# --- Hydra data store ---
HYDRA_DSN=sqlite:///var/lib/hydra/db.sqlite?_fk=true&mode=rwc

# --- Hydra secrets (REQUIRED — generate with `openssl rand -hex 32`) ---
# SECRETS_SYSTEM rotates the symmetric encryption key. First entry is active;
# add older keys (comma-separated) only when rotating.
HYDRA_SECRETS_SYSTEM=change-me-32-bytes-hex
HYDRA_SECRETS_COOKIE=change-me-32-bytes-hex
HYDRA_PAIRWISE_SALT=change-me-32-bytes-hex

# --- Hydra behavior ---
HYDRA_ACCESS_TOKEN_STRATEGY=jwt
HYDRA_TTL_ACCESS_TOKEN=1h
HYDRA_TTL_REFRESH_TOKEN=720h
HYDRA_TTL_ID_TOKEN=1h
HYDRA_TTL_AUTH_CODE=10m
HYDRA_LOG_LEVEL=info
HYDRA_LOG_LEAK_SENSITIVE_VALUES=false
HYDRA_EXPOSE_INTERNAL_ERRORS=false
# Set to "true" only on first boot if you need to bypass the HTTPS check while
# debugging behind a non-TLS proxy. Leave "false" in production.
HYDRA_DEV_MODE=false

# --- Login UI secrets ---
LOGIN_UI_COOKIE_SECRET=change-me-32-bytes-hex
LOGIN_UI_CSRF_COOKIE_SECRET=change-me-32-bytes-hex
LOGIN_UI_CSRF_COOKIE_NAME=__Host-ory-ui-csrf
# Keep "false" in production. Only set true if you serve Login UI over plain HTTP.
LOGIN_UI_DISABLE_SECURE_CSRF=false
